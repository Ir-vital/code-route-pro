# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="CodeRoute Pro"
APP_VERSION="1.0.0"
ENV=development
DEBUG=true

# ─── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://coderoute:coderoute_secret@localhost:5432/coderoute_db
DATABASE_ECHO=false

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS (liste séparée par virgules) ───────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_SIGNS=signs

# ─── Email SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_NAME="CodeRoute Pro"
EMAILS_FROM_ADDRESS=noreply@codeRoutepro.fr

# ─── Email Resend (prioritaire si défini, laisser vide pour SMTP) ─────────────
RESEND_API_KEY=

# ─── URL Frontend (pour les liens dans les emails) ────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Rate limiting ────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=10
LOGIN_RATE_LIMIT_WINDOW=300

# ─── Réinitialisation de mot de passe ────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=2
